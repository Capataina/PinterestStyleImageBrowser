images.db

# Project-local user-state directory. Holds DB, thumbnails, models,
# cosine cache, and settings — see paths.rs::app_data_dir(). Gitignored
# so user state never lands in commits.
Library/

# Local Claude Code personality — not shared
CLAUDE.md

# Python bytecode caches (created when scripts/ helpers are syntax-checked)
__pycache__/
*.pyc

# Belt-and-braces: any user-state files that might have accidentally
# been authored into the repo. Everything user-state-related lives in
# the platform app data directory (~/Library/Application Support/
# com.ataca.image-browser/ on macOS), but in case someone copies a
# stale .onnx or .db file in here while debugging:
*.onnx
*.db
*.db-journal
.thumbnails/
thumbnails/

# Cosine cache and any other binary scratch state
cosine_cache.bin
*.part
